<Window x:Class="SimpleUjianBrowser.HashToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buat Hash Password Admin"
        Width="560"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <!--
        Jendela utilitas operator. Dibuka lewat: SimpleUjianBrowser.exe --make-hash
        Tujuannya menghasilkan blok "adminPassword" untuk ditempel ke config.json
        di Firebase, tanpa pernah menyimpan password polos.
    -->
    <StackPanel Margin="24">
        <TextBlock Text="Buat Hash Password Admin"
                   Foreground="#CDD6F4" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Ketik password baru, klik Generate, lalu salin blok JSON ke config.json di Firebase."
                   Foreground="#A6ADC8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16" />

        <TextBlock Text="Password" Foreground="#CDD6F4" Margin="0,0,0,4" />
        <PasswordBox x:Name="PasswordInput" FontSize="14" Padding="8,6"
                     Background="#11111B" Foreground="#CDD6F4" CaretBrush="#CDD6F4" />

        <Button x:Name="GenerateButton" Content="Generate" Click="GenerateButton_Click"
                HorizontalAlignment="Left" Margin="0,12,0,0" Padding="16,8"
                Background="#89B4FA" Foreground="#1E1E2E" BorderThickness="0" Cursor="Hand" />

        <TextBlock Text="Hasil (blok adminPassword untuk config.json):"
                   Foreground="#CDD6F4" Margin="0,16,0,4" />
        <TextBox x:Name="OutputBox" IsReadOnly="True" FontFamily="Consolas" FontSize="13"
                 Background="#11111B" Foreground="#A6E3A1" TextWrapping="Wrap"
                 AcceptsReturn="True" Height="170" VerticalScrollBarVisibility="Auto" />

        <Button x:Name="CopyButton" Content="Salin" Click="CopyButton_Click"
                HorizontalAlignment="Left" Margin="0,12,0,0" Padding="16,8"
                Background="#94E2D5" Foreground="#1E1E2E" BorderThickness="0" Cursor="Hand" />
    </StackPanel>
</Window>
